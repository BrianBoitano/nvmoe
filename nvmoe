C_OK, C_WARN, C_ERR, C_END = "\033[32m", "\033[33m", "\033[31m", "\033[0m"


def say(tag, msg, color=C_OK):
    print(f"{color}[{tag}]{C_END} {msg}")


# ------------------------------------------------------------------ probes ---

def find_server_bin() -> Path | None:
    env = os.environ.get("NVMOE_BIN_DIR")
    candidates = [Path(env)] if env else []
    # apply.sh clones the fork into the repo; also accept a sibling checkout
    # and a prebuilt-release bin/ dropped at the repo root. Prefer the CUDA
    # build only when a GPU is actually visible — a CUDA binary on a
    # driverless box dies at startup.
    builds = ("build-cuda", "build") if gpu_vram_mb() else ("build", "build-cuda")
    for base in (ROOT / "llama.cpp-nvmoe", ROOT.parent / "llama.cpp-nvmoe"):
        candidates += [base / b / "bin" for b in builds]
    candidates += [ROOT / "bin"]
    for d in candidates:
        srv = d / "llama-server" if d else None
        if not (srv and srv.exists()):
            continue
        try:  # does it actually run on this machine?
            subprocess.run([str(srv), "--version"], capture_output=True, timeout=15)
            return d
        except Exception:
            continue
    return None


def gpu_vram_mb() -> int | None:
    smi = shutil.which("nvidia-smi")
    if not smi:
        return None
    try:
        out = subprocess.run([smi, "--query-gpu=memory.total", "--format=csv,noheader,nounits"],
                             capture_output=True, text=True, timeout=8).stdout.strip()
        return int(out.splitlines()[0])
    except Exception:
        return None


