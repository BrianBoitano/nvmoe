+// fetch-pool worker: take a job (mandatory misses before speculative
+// prefetches), read its extent into this reader's bounce slice, scatter it
+// into the pool, clear the slot's in-flight flag. The mutex is dropped
+// around the I/O so up to qd fetches overlap.
+static void llama_nvmoe_fetch(llama_nvmoe_layer * lyr, int32_t expert, int32_t slot, int reader);
+
+static void llama_nvmoe_worker(llama_nvmoe_context * nc, int reader) {
+    std::unique_lock<std::mutex> lock(nc->mtx);
+    for (;;) {
+        // speculative jobs may not occupy every worker: one stays free so a
+        // mandatory miss never waits behind a full pipe of speculation
+        auto can_spec = [&] { return !nc->q_spec.empty() && nc->n_spec_active < nc->qd - 1; };
+        nc->cv_work.wait(lock, [&] { return nc->stop_workers || !nc->q_mand.empty() || can_spec(); });
+        if (nc->stop_workers) {
+            return;
+        }
+        const bool spec = nc->q_mand.empty();
+        auto & q = spec ? nc->q_spec : nc->q_mand;
+        const llama_nvmoe_context::fetch_job job = q.front();
+        q.pop_front();
+        if (spec) {
+            nc->n_spec_active++;
+        }
+
+        lock.unlock();
+        const int64_t t0 = ggml_time_us();
+        llama_nvmoe_fetch(job.lyr, job.expert, job.slot, reader);
+        const int64_t dt = ggml_time_us() - t0;
+        lock.lock();
+
+        if (spec) {
+            nc->n_spec_active--;
+        }
+        nc->t_fetch_us += dt; // cumulative reader-busy time (fetches overlap)
+        nc->groups[job.lyr->group].slot_flight[job.slot] = 0;
+        nc->cv_done.notify_all();
+        nc->cv_work.notify_all(); // a spec slot may have opened up
+    }
+}
+
+void llama_nvmoe_init_lookahead(llama_nvmoe_context * nc,
+        const std::vector<ggml_tensor *> & ffn_norm,
+        const std::vector<ggml_tensor *> & gate_inp) {
+    // auto default: lookahead pays for itself where misses are plentiful
+    // (small cache budgets) and costs ~4% where they are not (its extra
+    // mul_mat launches, with CUDA graphs already disabled by the custom op,
+    // outweigh the rare hidden miss). Threshold: on when the cache holds
+    // under 60% of the paged experts. NVMOE_LOOKAHEAD forces either way.
+    {
+        int64_t slots = 0, all = 0;
+        std::vector<int64_t> group_layers(nc->groups.size(), 0);
+        for (auto & lyr : nc->layers) {
+            if (lyr) {
+                group_layers[lyr->group]++;
+            }
+        }
+        for (size_t gi = 0; gi < nc->groups.size(); gi++) {
+            slots += nc->groups[gi].n_slots;
+            all   += group_layers[gi] * nc->n_expert;
+        }
+        nc->lk_top = all > 0 && slots < all * 6 / 10 ? nc->n_expert_used : 0;
+    }
+    if (const char * s = getenv("NVMOE_LOOKAHEAD")) {
+        nc->lk_top = atoi(s);
+    }
+    nc->lk_top = std::max(0, std::min(nc->lk_top, (int) nc->n_expert));
+    if (nc->lk_top == 0) {
+        LLAMA_LOG_INFO("nvmoe: lookahead off (cache holds most experts; set NVMOE_LOOKAHEAD to force it on)\n");
+    }
+    if (const char * s = getenv("NVMOE_LOOKAHEAD_DEPTH")) {
+        nc->lk_depth = std::max(1, std::min(2, atoi(s)));
+    }
+    if (const char * s = getenv("NVMOE_PREFETCH")) {
+        nc->prefetch = atoi(s) != 0;
+    }
+    if (nc->lk_top == 0) {
+        return; // legacy synchronous path, none of the pool machinery runs
+    }
+
+    // chain each paged layer to its successors
+    {
+        std::vector<int> paged;
+        for (size_t il = 0; il < nc->layers.size(); il++) {
+            if (nc->layers[il]) {
+                paged.push_back((int) il);
+            }
+        }
+        for (size_t i = 0; i < paged.size(); i++) {
+            for (int k = 0; k < nc->lk_depth; k++) {
+                if (i + k + 1 < paged.size()) {
+                    nc->layers[paged[i]]->il_next[k] = paged[i + k + 1];
+                }
+            }
+        }
+    }
+
+    // small tensors (norm weights, routers) read to host as f32
+    auto read_f32 = [](ggml_tensor * t) -> std::vector<float> {
+        const int64_t n = ggml_nelements(t);
+        std::vector<float> v;
+        if (t->type == GGML_TYPE_F32) {
+            v.resize(n);
+            ggml_backend_tensor_get(t, v.data(), 0, n * sizeof(float));
+        } else if (t->type == GGML_TYPE_F16) {
+            std::vector<ggml_fp16_t> h(n);
+            ggml_backend_tensor_get(t, h.data(), 0, n * sizeof(ggml_fp16_t));
+            v.resize(n);
+            for (int64_t i = 0; i < n; i++) {
+                v[i] = ggml_fp16_to_fp32(h[i]);
+            }
+        }
+        return v;
+    };
+
+    // the lookahead routers predict il_next[k]'s routing from THIS layer's
+    // FFN input `cur = (x / rms(x)) * w_this`. il_next[k]'s true logits on
+    // the same residual x would be `gate_inp_ahead @ ((x / rms(x)) * w_ahead)`,
+    // so fold the norm-weight ratio into the router once, offline:
+    //     W'[h, e] = gate_inp_ahead[h, e] * w_ahead[h] / w_this[h]
+    // and the graph pays one extra mul_mat per layer per horizon. The only
+    // approximation left is the missing residual contributions of the
+    // layers in between (one FFN + one attention block per horizon step).
+    struct lk_plan {
+        llama_nvmoe_layer * lyr;
+        int                 horizon;
+        std::vector<float>  w; // [n_embd * n_expert]
+    };
+    std::vector<lk_plan> plans;
+    int64_t lk_bytes = 0;
+    for (auto & lyr : nc->layers) {
+        if (!lyr) {
+            continue;
+        }
+        for (int k = 0; k < nc->lk_depth; k++) {
+            const int il = lyr->il, jl = lyr->il_next[k];
+            if (jl < 0 || (size_t) il >= ffn_norm.size() || (size_t) jl >= ffn_norm.size() ||
+                    !ffn_norm[il] || !ffn_norm[jl] || !gate_inp[jl]) {
+                continue;
+            }
+            const int64_t n_embd = ffn_norm[il]->ne[0];
+            ggml_tensor * gi = gate_inp[jl];
+            if (gi->ne[0] != n_embd || gi->ne[1] != nc->n_expert || ffn_norm[jl]->ne[0] != n_embd) {
+                LLAMA_LOG_WARN("nvmoe: lookahead: unexpected router/norm shape at layer %d, skipping\n", il);
+                continue;
+            }
+            std::vector<float> wn_this = read_f32(ffn_norm[il]);
+            std::vector<float> wn_next = read_f32(ffn_norm[jl]);
+            std::vector<float> router  = read_f32(gi);
+            if (wn_this.empty() || wn_next.empty() || router.empty()) {
+                LLAMA_LOG_WARN("nvmoe: lookahead: unsupported tensor type at layer %d, skipping\n", il);
+                continue;
+            }
+            lk_plan p;
+            p.lyr     = lyr.get();
+            p.horizon = k;
+            p.w.resize((size_t) n_embd * nc->n_expert);
+            for (int64_t h = 0; h < n_embd; h++) {
+                const float d = wn_this[h];
+                const float r = fabsf(d) > 1e-30f ? wn_next[h] / d : 0.0f;
+                for (int64_t e = 0; e < nc->n_expert; e++) {
+                    p.w[(size_t) e * n_embd + h] = router[(size_t) e * n_embd + h] * r;
+                }
+            }
+            lk_bytes += (int64_t) p.w.size() * sizeof(float);
+            plans.push_back(std::move(p));
+        }
+    }
+
+    // allocate the routers grouped per buffer type, like the pools
+    {
+        std::vector<ggml_backend_buffer_type_t> bufts;
+        for (auto & p : plans) {
+            ggml_backend_buffer_type_t buft = nc->groups[p.lyr->group].buft;
+            if (std::find(bufts.begin(), bufts.end(), buft) == bufts.end()) {
+                bufts.push_back(buft);
+            }
+        }
+        for (auto buft : bufts) {
+            ggml_init_params ip = {
+                /*.mem_size   =*/ ggml_tensor_overhead() * plans.size(),
+                /*.mem_buffer =*/ nullptr,
+                /*.no_alloc   =*/ true,
+            };
+            ggml_context_ptr lctx { ggml_init(ip) };
+            if (!lctx) {
+                throw std::runtime_error("nvmoe: failed to create lookahead context");
+            }
+            for (auto & p : plans) {
+                if (nc->groups[p.lyr->group].buft != buft) {
+                    continue;
+                }
+                const int64_t n_embd = (int64_t) (p.w.size() / nc->n_expert);
+                ggml_tensor * t = ggml_new_tensor_2d(lctx.get(), GGML_TYPE_F32, n_embd, nc->n_expert);
+                ggml_format_name(t, "nvmoe_lk_router.%d.%d", p.lyr->il, p.horizon);
+                p.lyr->lk_router[p.horizon] = t;
+            }
+            ggml_backend_buffer_ptr buf { ggml_backend_alloc_ctx_tensors_from_buft(lctx.get(), buft) };
+            if (!buf) {
+                throw std::runtime_error(std::string("nvmoe: failed to allocate lookahead buffer in ") + ggml_backend_buft_name(buft));
+            }
+            ggml_backend_buffer_set_usage(buf.get(), GGML_BACKEND_BUFFER_USAGE_WEIGHTS);
+            nc->ctx_lk.emplace_back(std::move(lctx));
+            nc->buf_lk.emplace_back(std::move(buf));
+        }
+        for (auto & p : plans) {
+            ggml_backend_tensor_set(p.lyr->lk_router[p.horizon], p.w.data(), 0, p.w.size() * sizeof(float));
+        }
+    }
+
+    for (int r = 0; r < nc->qd; r++) {
+        nc->workers.emplace_back(llama_nvmoe_worker, nc, r);
+    }
+
+    LLAMA_LOG_INFO("nvmoe: lookahead top-%d depth-%d: %zu routers (%.1f MiB), %d fetch workers, prefetch %s\n",
+            nc->lk_top, nc->lk_depth, plans.size(), lk_bytes / 1024.0 / 1024.0, nc->qd,
+            nc->prefetch ? "on" : "off (stats only)");
+}
