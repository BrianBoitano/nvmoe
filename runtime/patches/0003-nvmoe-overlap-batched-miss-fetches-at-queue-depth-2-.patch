-// fetch one expert's extent from the pack and scatter its parts into slot
-static void llama_nvmoe_fetch(llama_nvmoe_layer * lyr, int32_t expert, int32_t slot) {
+// fetch one expert's extent from the pack and scatter its parts into slot;
+// reader selects a private slice of the bounce buffer so fetches can overlap
+static void llama_nvmoe_fetch(llama_nvmoe_layer * lyr, int32_t expert, int32_t slot, int reader) {
     llama_nvmoe_context * nc = lyr->ctx;
     llama_nvmoe_group   & g  = nc->groups[lyr->group];
 
-    const int64_t t0 = ggml_time_us();
+    char * bounce = (char *) nc->bounce + (size_t) reader * nc->bounce_stride;
 
     const uint64_t off = lyr->ext_off[expert];
     size_t done = 0;
     while (done < lyr->group_stride) {
-        const ssize_t r = pread(nc->fd, (char *) nc->bounce + done, lyr->group_stride - done, off + done);
+        const ssize_t r = pread(nc->fd, bounce + done, lyr->group_stride - done, off + done);
         if (r <= 0) {
             GGML_ABORT("nvmoe: pack read failed at offset %" PRIu64 ": %s", off + done, r == 0 ? "eof" : strerror(errno));
         }
@@ -349,15 +358,19 @@ static void llama_nvmoe_fetch(llama_nvmoe_layer * lyr, int32_t expert, int32_t s
         }
         ggml_tensor * pool = g.pool[k];
         // memcpy on CPU buffers, a synchronous H2D copy on device buffers
-        ggml_backend_tensor_set(pool, (const char *) nc->bounce + p.rel_off, (size_t) slot * pool->nb[2], p.slice_bytes);
+        ggml_backend_tensor_set(pool, bounce + p.rel_off, (size_t) slot * pool->nb[2], p.slice_bytes);
     }
-
-    nc->n_bytes    += lyr->group_stride;
-    nc->t_fetch_us += ggml_time_us() - t0;
 }
 
 // the custom op: for every selected expert id, make sure the expert is
-// resident in the pool and write out its slot index
+// resident in the pool and write out its slot index.
+//
+// Two passes: the first walks the ids, resolves hits, and assigns victim
+// slots for the distinct misses; the fetches then run with LLAMA_NVMOE_QD
+// concurrent readers (multi-MB extent reads peak at queue depth 2-4 on
+// NVMe — measured in paging/ — and both pread and cudaMemcpy are
+// thread-safe). Decode ops rarely miss more than once, but cold starts,
+// prefill sweeps, and small cache budgets batch many misses per op.
 static void llama_nvmoe_fetch_op(ggml_tensor * dst, const ggml_tensor * a, int ith, int nth, void * userdata) {
     GGML_UNUSED(nth);
     if (ith != 0) {
@@ -376,6 +389,8 @@ static void llama_nvmoe_fetch_op(ggml_tensor * dst, const ggml_tensor * a, int i
     const int32_t * ids = (const int32_t *) a->data;
     int32_t       * out = (int32_t *) dst->data;
 
+    std::vector<std::pair<int32_t, int32_t>> misses; // (expert, slot)
+
     for (int64_t i = 0; i < n; i++) {
         const int32_t e = ids[i];
         GGML_ASSERT(e >= 0 && e < nc->n_expert);
@@ -409,10 +424,10 @@ static void llama_nvmoe_fetch_op(ggml_tensor * dst, const ggml_tensor * a, int i
                 g.where.erase(g.slot_key[slot]);
             }
 
-            llama_nvmoe_fetch(lyr, e, slot);
-
             g.slot_key[slot] = key;
             g.where[key]     = slot;
+
+            misses.emplace_back(e, slot);
         }
 
         nc->n_ref++;
@@ -421,6 +436,32 @@ static void llama_nvmoe_fetch_op(ggml_tensor * dst, const ggml_tensor * a, int i
 
         out[i] = slot;
     }
+
+    if (misses.empty()) {
+        return;
+    }
+
+    const int64_t t0 = ggml_time_us();
+    if (misses.size() == 1) {
+        llama_nvmoe_fetch(lyr, misses[0].first, misses[0].second, 0);
+    } else {
+        const int n_readers = std::min<int>(nc->qd, (int) misses.size());
+        std::vector<std::thread> readers;
+        std::atomic<size_t> next(0);
+        for (int r = 0; r < n_readers; r++) {
+            readers.emplace_back([&, r]() {
+                for (size_t m; (m = next.fetch_add(1)) < misses.size(); ) {
+                    llama_nvmoe_fetch(lyr, misses[m].first, misses[m].second, r);
+                }
+            });
+        }
+        for (auto & t : readers) {
+            t.join();
+        }
+    }
+    // wall time, not per-reader time, when fetches overlap
+    nc->t_fetch_us += ggml_time_us() - t0;
+    nc->n_bytes    += misses.size() * lyr->group_stride;
 }
 
