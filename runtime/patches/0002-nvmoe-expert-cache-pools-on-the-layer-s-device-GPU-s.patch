+        // pinned bounce when any pool sits on a GPU: tensor_set from pinned
+        // pages is a straight DMA, and O_DIRECT accepts them (page-aligned)
+        for (ggml_backend_dev_t dev : layer_dev) {
+            if (!dev || dev == cpu_dev) {
+                continue;
+            }
+            ggml_backend_buffer_type_t hbuft = ggml_backend_dev_host_buffer_type(dev);
+            if (!hbuft) {
+                continue;
+            }
+            ctx->buf_bounce.reset(ggml_backend_buft_alloc_buffer(hbuft, ctx->bounce_size));
+            if (ctx->buf_bounce) {
+                ctx->bounce = ggml_backend_buffer_get_base(ctx->buf_bounce.get());
+                LLAMA_LOG_INFO("nvmoe: %6.1f MiB pinned bounce buffer (%s)\n",
