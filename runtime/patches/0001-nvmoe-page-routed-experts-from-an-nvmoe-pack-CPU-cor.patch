+        GGML_ASSERT(up_exps_s == nullptr && gate_exps_s == nullptr && down_exps_s == nullptr &&
+                "nvmoe: per-expert weight scales not supported with paged experts");
+        GGML_ASSERT(arch != LLM_ARCH_GROVEMOE && "nvmoe: grovemoe id-division not supported with paged experts");
+
+        ids_mm = llama_nvmoe_ids_remap(ctx0, lyr, selected_experts);
+        cb(ids_mm, "ffn_moe_topk_nvmoe", il);
+
+        gate_exps = llama_nvmoe_pool(lyr, LLAMA_NVMOE_GATE);
+        up_exps   = llama_nvmoe_pool(lyr, LLAMA_NVMOE_UP);
+        down_exps = llama_nvmoe_pool(lyr, LLAMA_NVMOE_DOWN);
+        GGML_ASSERT(up_exps != nullptr && down_exps != nullptr);
