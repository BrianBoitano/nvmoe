+
+#include <cerrno>
+#include <cinttypes>
+#include <cstdlib>
+#include <cstring>
+#include <fstream>
+#include <stdexcept>
+
+using json = nlohmann::ordered_json;
+
+static const char * llama_nvmoe_kind_names[LLAMA_NVMOE_KIND_COUNT] = {
+    "ffn_gate_exps",
+    "ffn_up_exps",
+    "ffn_down_exps",
+};
+
+llama_nvmoe_context::~llama_nvmoe_context() {
+    if (n_ref > 0) {
+        LLAMA_LOG_INFO("nvmoe: %" PRIu64 " expert refs, %" PRIu64 " misses (%.2f%% hit), %.1f MiB fetched, %.3f s fetch time\n",
+                n_ref, n_miss, 100.0 * (n_ref - n_miss) / n_ref,
+                n_bytes / 1024.0 / 1024.0, t_fetch_us / 1e6);
+    }
+    if (fd >= 0) {
+        close(fd);
+    }
+    free(bounce);
+}
+
+llama_nvmoe_context * llama_nvmoe_init(const std::string & pack_dir, const std::string & manifest_name, int64_t cache_bytes) {
+    auto ctx = std::make_unique<llama_nvmoe_context>();
+    ctx->dir = pack_dir;
+
+    const std::string manifest_path = pack_dir + "/" + manifest_name;
+
+    json m;
+    {
+        std::ifstream f(manifest_path);
+        if (!f) {
+            throw std::runtime_error("nvmoe: cannot open manifest " + manifest_path);
+        }
+        f >> m;
+    }
+
+    if (m.value("format", "") != "nvmoe-pack" || m.value("format_version", 0) != 1) {
+        throw std::runtime_error("nvmoe: unsupported pack format in " + manifest_path);
+    }
+
+    ctx->alignment     = m.value("alignment", 4096);
+    ctx->n_expert      = m["model"]["n_expert"].get<int32_t>();
+    ctx->n_expert_used = m["model"]["n_expert_used"].get<int32_t>();
+
+    const int n_layers_total = m["model"]["n_layers_total"].get<int>();
+    ctx->layers.resize(n_layers_total);
+
+    // per-layer geometry
+    for (const auto & [key, jl] : m["layers"].items()) {
+        const int il = std::stoi(key);
+        if (il < 0 || il >= n_layers_total) {
+            throw std::runtime_error("nvmoe: manifest layer index out of range");
+        }
+        auto lyr = std::make_unique<llama_nvmoe_layer>();
+        lyr->ctx = ctx.get();
+        lyr->il  = il;
+        lyr->group_bytes  = jl["group_bytes"].get<size_t>();
+        lyr->group_stride = jl["group_stride"].get<size_t>();
+        lyr->ext_off.assign(ctx->n_expert, 0);
+
+        for (const auto & [kname, jp] : jl["parts"].items()) {
+            int kind = -1;
+            for (int k = 0; k < LLAMA_NVMOE_KIND_COUNT; k++) {
+                if (kname == llama_nvmoe_kind_names[k]) {
+                    kind = k;
+                    break;
+                }
+            }
+            if (kind < 0) {
+                throw std::runtime_error("nvmoe: unknown part kind '" + kname + "' in manifest");
+            }
+            auto & p = lyr->parts[kind];
+            p.present     = true;
+            p.type        = (ggml_type) jp["ggml_type"].get<int>();
+            p.ne0         = jp["ne"][0].get<int64_t>();
+            p.ne1         = jp["ne"][1].get<int64_t>();
+            p.slice_bytes = jp["slice_bytes"].get<size_t>();
+            p.rel_off     = jp["rel_off"].get<size_t>();
+
+            // cross-check the manifest against ggml's own row math
+            const size_t row_bytes = ggml_row_size(p.type, p.ne0);
+            if (row_bytes * p.ne1 != p.slice_bytes) {
+                throw std::runtime_error("nvmoe: manifest slice_bytes mismatch for " + kname);
+            }
+        }
+        ctx->bounce_size = std::max(ctx->bounce_size, lyr->group_stride);
+        ctx->layers[il] = std::move(lyr);
+    }
+
+    // extent offsets
+    for (const auto & g : m["groups"]) {
+        const int      il = g[0].get<int>();
+        const int       e = g[1].get<int>();
+        const uint64_t off = g[2].get<uint64_t>();
+        if (il < 0 || il >= n_layers_total || !ctx->layers[il] || e < 0 || e >= ctx->n_expert) {
+            throw std::runtime_error("nvmoe: bad group entry in manifest");
+        }
+        ctx->layers[il]->ext_off[e] = off;
+    }
+
+    // geometry groups: layers whose parts all match share pools and cache slots
+    struct sig_entry {
+        llama_nvmoe_part parts[LLAMA_NVMOE_KIND_COUNT];
+        int group;
+        int n_layers;
+    };
+    std::vector<sig_entry> sigs;
+    for (auto & lyr : ctx->layers) {
+        if (!lyr) {
+            continue;
+        }
+        int found = -1;
+        for (auto & s : sigs) {
+            bool same = true;
+            for (int k = 0; k < LLAMA_NVMOE_KIND_COUNT && same; k++) {
+                const auto & a = s.parts[k];
+                const auto & b = lyr->parts[k];
+                same = a.present == b.present && a.type == b.type && a.ne0 == b.ne0 && a.ne1 == b.ne1;
+            }
+            if (same) {
+                found = s.group;
+                break;
+            }
+        }
+        if (found < 0) {
+            found = (int) sigs.size();
+            sig_entry s = {};
+            memcpy(s.parts, lyr->parts, sizeof(s.parts));
+            s.group    = found;
+            s.n_layers = 0;
+            sigs.push_back(s);
+        }
+        sigs[found].n_layers++;
+        lyr->group = found;
+    }
+
+    // slot budget: default everything resident; with a byte budget, split it
+    // across groups proportionally to their share of the paged bytes, floored
+    // at n_expert slots so any single mul_mat_id fits in its group's pool
+    size_t total_paged = 0;
+    std::vector<size_t> group_paged(sigs.size(), 0);
+    for (auto & lyr : ctx->layers) {
+        if (!lyr) {
+            continue;
+        }
+        group_paged[lyr->group] += lyr->group_bytes * ctx->n_expert;
+        total_paged             += lyr->group_bytes * ctx->n_expert;
+    }
+
+    ctx->groups.resize(sigs.size());
+    for (auto & s : sigs) {
+        auto & g = ctx->groups[s.group];
+
+        // bytes of one slot = one expert's extent payload (uniform within a group)
+        size_t slot_bytes = 0;
+        for (int k = 0; k < LLAMA_NVMOE_KIND_COUNT; k++) {
+            if (s.parts[k].present) {
+                slot_bytes += s.parts[k].slice_bytes;
+            }
+        }
+
+        const int64_t all_slots = (int64_t) s.n_layers * ctx->n_expert;
+        int64_t n_slots = all_slots;
+        if (cache_bytes > 0) {
+            const int64_t budget = (int64_t) ((double) cache_bytes * group_paged[s.group] / total_paged);
+            n_slots = std::min<int64_t>(all_slots, std::max<int64_t>(ctx->n_expert, budget / (int64_t) slot_bytes));
+        }
+        g.n_slots = (int32_t) n_slots;
+
+        g.slot_key .assign(g.n_slots, -1);
+        g.slot_used.assign(g.n_slots,  0);
+        g.slot_op  .assign(g.n_slots,  0);
+    }
+
+    // pool tensors, allocated in one CPU buffer
+    {
+        const size_t n_pools = sigs.size() * LLAMA_NVMOE_KIND_COUNT;
+        ggml_init_params ip = {
+            /*.mem_size   =*/ ggml_tensor_overhead() * n_pools,
+            /*.mem_buffer =*/ nullptr,
+            /*.no_alloc   =*/ true,
+        };
+        ctx->ctx_pools.reset(ggml_init(ip));
+        if (!ctx->ctx_pools) {
+            throw std::runtime_error("nvmoe: failed to create pool context");
+        }
+
+        for (auto & s : sigs) {
+            auto & g = ctx->groups[s.group];
+            for (int k = 0; k < LLAMA_NVMOE_KIND_COUNT; k++) {
+                if (!s.parts[k].present) {
+                    continue;
+                }
+                ggml_tensor * t = ggml_new_tensor_3d(ctx->ctx_pools.get(), s.parts[k].type, s.parts[k].ne0, s.parts[k].ne1, g.n_slots);
+                ggml_format_name(t, "nvmoe_pool_g%d.%s", s.group, llama_nvmoe_kind_names[k]);
+                g.pool[k] = t;
+            }
+        }
+
+        ctx->buf_pools.reset(ggml_backend_alloc_ctx_tensors_from_buft(ctx->ctx_pools.get(), ggml_backend_cpu_buffer_type()));
+        if (!ctx->buf_pools) {
+            throw std::runtime_error("nvmoe: failed to allocate pool buffers");
+        }
+        ggml_backend_buffer_set_usage(ctx->buf_pools.get(), GGML_BACKEND_BUFFER_USAGE_WEIGHTS);
+
+        LLAMA_LOG_INFO("nvmoe: %zu pool group(s), %8.2f MiB expert cache (%s)\n",
+                sigs.size(), ggml_backend_buffer_get_size(ctx->buf_pools.get()) / 1024.0 / 1024.0,
+                cache_bytes > 0 ? "budgeted" : "all experts resident");
+    }
+
+    // pack file + bounce buffer
+    {
+        const std::string pack_path = pack_dir + "/" + m["files"]["expert_pack"].get<std::string>();
+
+        const bool no_direct = getenv("NVMOE_NO_DIRECT") != nullptr;
+        if (!no_direct) {
+            ctx->fd = open(pack_path.c_str(), O_RDONLY | O_DIRECT);
+            ctx->direct_io = ctx->fd >= 0;
+        }
+        if (ctx->fd < 0) {
+            ctx->fd = open(pack_path.c_str(), O_RDONLY);
+        }
+        if (ctx->fd < 0) {
+            throw std::runtime_error("nvmoe: cannot open pack " + pack_path + ": " + strerror(errno));
+        }
+
+        if (posix_memalign(&ctx->bounce, ctx->alignment, ctx->bounce_size) != 0) {
+            throw std::runtime_error("nvmoe: failed to allocate bounce buffer");
+        }
+
+        // header read is one aligned block, so it works under O_DIRECT too
+        if (pread(ctx->fd, ctx->bounce, ctx->alignment, 0) != (ssize_t) ctx->alignment) {
+            throw std::runtime_error("nvmoe: cannot read pack header");
+        }
+        if (memcmp(ctx->bounce, "NVMOEPK1", 8) != 0) {
+            throw std::runtime_error("nvmoe: bad pack magic in " + pack_path);
+        }
+
+        LLAMA_LOG_INFO("nvmoe: pack %s opened (O_DIRECT %s)\n", pack_path.c_str(), ctx->direct_io ? "on" : "off");
+    }
+
+    return ctx.release();
+}
+
+llama_nvmoe_layer * llama_nvmoe_get_layer(const llama_nvmoe_context * ctx, int il) {
+    if (il < 0 || (size_t) il >= ctx->layers.size()) {
+        return nullptr;
+    }
+    return ctx->layers[il].get();
+}
+
+ggml_tensor * llama_nvmoe_pool(const llama_nvmoe_layer * lyr, llama_nvmoe_kind kind) {
+    return lyr->ctx->groups[lyr->group].pool[kind];
+}
+
+// fetch one expert's extent from the pack and scatter its parts into slot
+static void llama_nvmoe_fetch(llama_nvmoe_layer * lyr, int32_t expert, int32_t slot) {
+    llama_nvmoe_context * nc = lyr->ctx;
+    llama_nvmoe_group   & g  = nc->groups[lyr->group];
+
+    const int64_t t0 = ggml_time_us();
+
+    const uint64_t off = lyr->ext_off[expert];
+    size_t done = 0;
+    while (done < lyr->group_stride) {
+        const ssize_t r = pread(nc->fd, (char *) nc->bounce + done, lyr->group_stride - done, off + done);
+        if (r <= 0) {
+            GGML_ABORT("nvmoe: pack read failed at offset %" PRIu64 ": %s", off + done, r == 0 ? "eof" : strerror(errno));
+        }
+        done += r;
+    }
+
+    for (int k = 0; k < LLAMA_NVMOE_KIND_COUNT; k++) {
+        const auto & p = lyr->parts[k];
+        if (!p.present) {
+            continue;
+        }
+        ggml_tensor * pool = g.pool[k];
+        memcpy((char *) pool->data + (size_t) slot * pool->nb[2], (const char *) nc->bounce + p.rel_off, p.slice_bytes);
+    }
+
+    nc->n_bytes    += lyr->group_stride;
+    nc->t_fetch_us += ggml_time_us() - t0;
+}
+
+// the custom op: for every selected expert id, make sure the expert is
+// resident in the pool and write out its slot index
+static void llama_nvmoe_fetch_op(ggml_tensor * dst, const ggml_tensor * a, int ith, int nth, void * userdata) {
+    GGML_UNUSED(nth);
+    if (ith != 0) {
+        return;
+    }
+
+    GGML_ASSERT(a->type == GGML_TYPE_I32 && ggml_is_contiguous(a));
+
+    llama_nvmoe_layer   * lyr = (llama_nvmoe_layer *) userdata;
+    llama_nvmoe_context * nc  = lyr->ctx;
+    llama_nvmoe_group   & g   = nc->groups[lyr->group];
+
+    nc->epoch++;
+
+    const int64_t n = ggml_nelements(a);
+    const int32_t * ids = (const int32_t *) a->data;
+    int32_t       * out = (int32_t *) dst->data;
+
+    for (int64_t i = 0; i < n; i++) {
+        const int32_t e = ids[i];
+        GGML_ASSERT(e >= 0 && e < nc->n_expert);
+
+        const int64_t key = ((int64_t) lyr->il << 32) | (uint32_t) e;
+
+        int32_t slot;
+        const auto it = g.where.find(key);
+        if (it != g.where.end()) {
+            slot = it->second;
+        } else {
+            nc->n_miss++;
+
+            // victim: first empty slot, else LRU among slots not pinned by this op
+            slot = -1;
+            uint64_t best = UINT64_MAX;
+            for (int32_t s = 0; s < g.n_slots; s++) {
+                if (g.slot_key[s] < 0) {
+                    slot = s;
+                    break;
+                }
+                if (g.slot_op[s] != nc->epoch && g.slot_used[s] < best) {
+                    best = g.slot_used[s];
+                    slot = s;
+                }
+            }
+            if (slot < 0) {
+                GGML_ABORT("nvmoe: expert cache too small for a single op (n_slots = %d)", g.n_slots);
+            }
+            if (g.slot_key[slot] >= 0) {
+                g.where.erase(g.slot_key[slot]);
+            }
+
+            llama_nvmoe_fetch(lyr, e, slot);
+
+            g.slot_key[slot] = key;
+            g.where[key]     = slot;
+        }
+
+        nc->n_ref++;
+        g.slot_used[slot] = ++nc->tick;
+        g.slot_op[slot]   = nc->epoch;
+
+        out[i] = slot;
+    }
+}
+
+ggml_tensor * llama_nvmoe_ids_remap(ggml_context * ctx0, llama_nvmoe_layer * lyr, ggml_tensor * selected_experts) {
+    // selected_experts is usually a strided view (argsort_top_k); the op wants flat i32
+    if (!ggml_is_contiguous(selected_experts)) {
+        selected_experts = ggml_cont(ctx0, selected_experts);
+    }
+    return ggml_map_custom1(ctx0, selected_experts, llama_nvmoe_fetch_op, 1, lyr);
+}
diff --git a/src/llama-nvmoe.h b/src/llama-nvmoe.h
new file mode 100644
index 0000000..f0c638b
--- /dev/null
+++ b/src/llama-nvmoe.h
@@ -0,0 +1,121 @@
+#pragma once
+
+// nvmoe: paged routed experts
+//
+// When a model is loaded from an nvmoe pack (see nvmoe's docs/PACK_FORMAT.md),
+// the routed-expert weights are not loaded into memory at all. Instead:
+//
+//   - resident.gguf goes through the normal loader minus the
+//     blk.*.ffn_{gate,up,down}_exps.weight tensors
+//   - this module owns fixed-size "pool" tensors [ne0, ne1, n_slots] per
+//     matrix kind, shared by all MoE layers with the same geometry, backed by
+//     an LRU cache keyed (layer, expert) -> slot
+//   - build_moe_ffn() inserts a custom op on the selected-experts ids that
+//     fetches missing experts from experts.pack (synchronous O_DIRECT read on
+//     miss) and emits ids remapped to pool slots, so ggml_mul_mat_id runs
+//     unchanged on the pool tensors
+//
+// State lives on the llama_model; one llama_context per model at a time (the
+// custom op mutates the cache with no locking across contexts).
+
+#include "ggml.h"
+#include "ggml-backend.h"
+#include "ggml-cpp.h"
+
+#include <cstdint>
+#include <memory>
+#include <string>
+#include <unordered_map>
+#include <vector>
+
+enum llama_nvmoe_kind {
+    LLAMA_NVMOE_GATE = 0,
+    LLAMA_NVMOE_UP   = 1,
+    LLAMA_NVMOE_DOWN = 2,
+    LLAMA_NVMOE_KIND_COUNT,
+};
+
+struct llama_nvmoe_context;
+
+// one matrix kind of one layer, as described by the pack manifest
+struct llama_nvmoe_part {
+    bool      present = false;
+    ggml_type type    = GGML_TYPE_COUNT;
+    int64_t   ne0     = 0;
+    int64_t   ne1     = 0;
+    size_t    slice_bytes = 0; // bytes of one expert's matrix
+    size_t    rel_off     = 0; // offset inside the extent
+};
+
+struct llama_nvmoe_layer {
+    llama_nvmoe_context * ctx = nullptr;
+
+    int il    = -1;
+    int group = -1; // index into llama_nvmoe_context::groups
+
+    llama_nvmoe_part parts[LLAMA_NVMOE_KIND_COUNT];
+
+    size_t group_bytes  = 0; // payload bytes per extent
+    size_t group_stride = 0; // padded to pack alignment
+
+    std::vector<uint64_t> ext_off; // absolute pack offset per expert
+};
+
+// layers with identical part geometry share pool tensors and cache slots
+struct llama_nvmoe_group {
+    ggml_tensor * pool[LLAMA_NVMOE_KIND_COUNT] = {};
+
+    int32_t n_slots = 0;
+
+    // cache state; key = (layer << 32) | expert
+    std::vector<int64_t>  slot_key;  // -1 = empty
+    std::vector<uint64_t> slot_used; // last-use tick (LRU)
+    std::vector<uint64_t> slot_op;   // op epoch that pinned the slot
+    std::unordered_map<int64_t, int32_t> where;
+};
+
+struct llama_nvmoe_context {
+    std::string dir;
+
+    int    fd        = -1;
+    bool   direct_io = false;
+    size_t alignment = 4096;
+
+    int32_t n_expert      = 0;
+    int32_t n_expert_used = 0;
+
+    std::vector<std::unique_ptr<llama_nvmoe_layer>> layers; // indexed by il, null for non-MoE layers
+    std::vector<llama_nvmoe_group> groups;
+
+    // pool tensor storage (host memory in the CPU correctness path)
+    ggml_context_ptr           ctx_pools;
+    ggml_backend_buffer_ptr    buf_pools;
+
+    // O_DIRECT-aligned bounce buffer, large enough for the largest extent
+    void * bounce      = nullptr;
+    size_t bounce_size = 0;
+
+    uint64_t tick  = 0; // LRU clock
+    uint64_t epoch = 0; // custom-op invocation counter (for per-op pinning)
+
+    // stats, counted per expert reference (top_k * n_tokens per layer op)
+    uint64_t n_ref   = 0;
+    uint64_t n_miss  = 0;
+    uint64_t n_bytes = 0;  // bytes fetched from the pack
+    int64_t  t_fetch_us = 0;
+
+    ~llama_nvmoe_context();
+};
+
+// load manifest + open pack; cache_bytes <= 0 means "all experts resident".
+// throws std::runtime_error on any problem.
+llama_nvmoe_context * llama_nvmoe_init(const std::string & pack_dir, const std::string & manifest_name, int64_t cache_bytes);
+
+// per-layer handle for graph building; null if il is not a paged MoE layer
+llama_nvmoe_layer * llama_nvmoe_get_layer(const llama_nvmoe_context * ctx, int il);
+
+// pool tensor for a kind; null if the arch has no such matrix
+ggml_tensor * llama_nvmoe_pool(const llama_nvmoe_layer * lyr, llama_nvmoe_kind kind);
+
+// build-time: wrap selected_experts in the fetch+remap custom op
+ggml_tensor * llama_nvmoe_ids_remap(ggml_context * ctx0, llama_nvmoe_layer * lyr, ggml_tensor * selected_experts);
