diff --git a/examples/nvmoe-logits/nvmoe-logits.cpp b/examples/nvmoe-logits/nvmoe-logits.cpp
new file mode 100644
index 0000000..66a5d61
--- /dev/null
+++ b/examples/nvmoe-logits/nvmoe-logits.cpp
@@ -0,0 +1,195 @@
+// nvmoe-logits: the nvmoe correctness gate.
+//
+// Greedy-decodes N tokens from a fixed prompt and dumps the FULL logits
+// vector at every step to a binary file. Run it twice — once on the original
+// GGUF, once on the pack's resident.gguf — and compare the dumps with
+// nvmoe's tools/compare_logits.py. On the CPU backend the two dumps must be
+// byte-identical: the pack path computes the same matmuls on the same bytes.
+//
+// Deliberately raw llama.h API (no common/), so the tool itself has no
+// sampling, no warmup, and no hidden state.
+//
+// usage: llama-nvmoe-logits -m model.gguf -o out.bin [-p PROMPT] [-n N_GEN] [-t N_THREADS] [-ngl N]
+//
+// dump format (little-endian):
+//   char[8]  magic "NVMLOG01"
+//   u32      n_vocab
+//   u32      n_prompt,  u32 prompt_tokens[n_prompt]
+//   u32      n_steps
+//   per step: u32 chosen_token, f32 logits[n_vocab]
+
+#include "llama.h"
+#include "ggml.h"
+#include "ggml-backend.h"
+
+#include <cmath>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <string>
+#include <vector>
+
+// -d mode: print a checksum line for every observed graph tensor, to bisect
+// where two runs diverge (compare the logs with diff)
+static bool dump_cb(struct ggml_tensor * t, bool ask, void * user_data) {
+    if (ask) {
+        return t->name[0] != '\0';
+    }
+    FILE * f = (FILE *) user_data;
+    if (t->type == GGML_TYPE_F32) {
+        std::vector<float> v(ggml_nelements(t));
+        ggml_backend_tensor_get(t, v.data(), 0, v.size() * sizeof(float));
+        double sum = 0;
+        for (float x : v) sum += (double) x;
+        fprintf(f, "%-40s %14.6e\n", t->name, sum);
+    } else if (t->type == GGML_TYPE_I32) {
+        std::vector<int32_t> v(ggml_nelements(t));
+        ggml_backend_tensor_get(t, v.data(), 0, v.size() * sizeof(int32_t));
+        long sum = 0;
+        for (int32_t x : v) sum += x;
+        fprintf(f, "%-40s i32 sum %ld\n", t->name, sum);
+    }
+    return true;
+}
+
+int main(int argc, char ** argv) {
+    std::string model_path;
+    std::string out_path;
+    std::string dump_path;
+    std::string prompt  = "The capital of France is";
+    int n_gen     = 32;
+    int n_threads = 8;
+    int n_gpu_layers = 0;
+
+    for (int i = 1; i < argc; i++) {
+        auto need = [&](const char * flag) -> const char * {
+            if (i + 1 >= argc) {
+                fprintf(stderr, "missing value for %s\n", flag);
+                exit(1);
+            }
+            return argv[++i];
+        };
+        if      (!strcmp(argv[i], "-m"))   model_path   = need("-m");
+        else if (!strcmp(argv[i], "-o"))   out_path     = need("-o");
+        else if (!strcmp(argv[i], "-d"))   dump_path    = need("-d");
+        else if (!strcmp(argv[i], "-p"))   prompt       = need("-p");
+        else if (!strcmp(argv[i], "-n"))   n_gen        = atoi(need("-n"));
+        else if (!strcmp(argv[i], "-t"))   n_threads    = atoi(need("-t"));
+        else if (!strcmp(argv[i], "-ngl")) n_gpu_layers = atoi(need("-ngl"));
+        else {
+            fprintf(stderr, "unknown arg %s\n", argv[i]);
+            return 1;
+        }
+    }
+    if (model_path.empty() || out_path.empty()) {
+        fprintf(stderr, "usage: %s -m model.gguf -o out.bin [-p PROMPT] [-n N_GEN] [-t N_THREADS] [-ngl N]\n", argv[0]);
+        return 1;
+    }
+
+    llama_backend_init();
+
+    llama_model_params mparams = llama_model_default_params();
+    mparams.n_gpu_layers = n_gpu_layers;
+    // no weight repacking: the CPU "extra" buffer types rewrite quantized
+    // weights into an interleaved layout whose kernels sum in a different
+    // order. nvmoe pool tensors are plain buffers, so for a bit-identical
+    // stock-vs-pack comparison both runs must use the plain kernels.
+    mparams.use_extra_bufts = false;
+
+    llama_model * model = llama_model_load_from_file(model_path.c_str(), mparams);
+    if (!model) {
+        fprintf(stderr, "failed to load %s\n", model_path.c_str());
+        return 1;
+    }
+    const llama_vocab * vocab = llama_model_get_vocab(model);
+    const int32_t n_vocab = llama_vocab_n_tokens(vocab);
+
+    llama_context_params cparams = llama_context_default_params();
+    cparams.n_ctx           = 4096;
+    cparams.n_threads       = n_threads;
+    cparams.n_threads_batch = n_threads;
+
+    FILE * fdump = nullptr;
+    if (!dump_path.empty()) {
+        fdump = fopen(dump_path.c_str(), "w");
+        if (!fdump) {
+            fprintf(stderr, "cannot open %s\n", dump_path.c_str());
+            return 1;
+        }
+        cparams.cb_eval           = dump_cb;
+        cparams.cb_eval_user_data = fdump;
+    }
+
+    llama_context * ctx = llama_init_from_model(model, cparams);
+    if (!ctx) {
+        fprintf(stderr, "failed to create context\n");
+        return 1;
+    }
+
+    // tokenize
+    std::vector<llama_token> tokens(prompt.size() + 16);
+    const int n_prompt = llama_tokenize(vocab, prompt.c_str(), (int32_t) prompt.size(),
+            tokens.data(), (int32_t) tokens.size(), /*add_special*/ true, /*parse_special*/ false);
+    if (n_prompt <= 0) {
+        fprintf(stderr, "tokenization failed\n");
+        return 1;
+    }
+    tokens.resize(n_prompt);
+
+    FILE * fout = fopen(out_path.c_str(), "wb");
+    if (!fout) {
+        fprintf(stderr, "cannot open %s\n", out_path.c_str());
+        return 1;
+    }
+    fwrite("NVMLOG01", 1, 8, fout);
+    const uint32_t nv = n_vocab, np = n_prompt, ns = n_gen;
+    fwrite(&nv, 4, 1, fout);
+    fwrite(&np, 4, 1, fout);
+    for (auto t : tokens) {
+        const uint32_t u = t;
+        fwrite(&u, 4, 1, fout);
+    }
+    fwrite(&ns, 4, 1, fout);
+
+    // prompt, then greedy decode; dump logits after every llama_decode
+    llama_batch batch = llama_batch_get_one(tokens.data(), n_prompt);
+
+    fprintf(stderr, "prompt: '%s' (%d tokens), generating %d...\n", prompt.c_str(), n_prompt, n_gen);
+
+    llama_token cur = -1;
+    for (int step = 0; step < n_gen; step++) {
+        if (llama_decode(ctx, batch) != 0) {
+            fprintf(stderr, "llama_decode failed at step %d\n", step);
+            return 1;
+        }
+        const float * logits = llama_get_logits_ith(ctx, -1);
+
+        // greedy argmax, lowest id wins ties
+        cur = 0;
+        for (int32_t i = 1; i < n_vocab; i++) {
+            if (logits[i] > logits[cur]) {
+                cur = i;
+            }
+        }
+
+        const uint32_t u = cur;
+        fwrite(&u, 4, 1, fout);
+        fwrite(logits, 4, n_vocab, fout);
+
+        char buf[256];
+        const int n = llama_token_to_piece(vocab, cur, buf, sizeof(buf), 0, false);
+        fprintf(stderr, "%.*s", n > 0 ? n : 0, buf);
+        fflush(stderr);
+
+        batch = llama_batch_get_one(&cur, 1);
+    }
+    fprintf(stderr, "\n");
+    fclose(fout);
+
+    llama_perf_context_print(ctx);
+
+    llama_free(ctx);
+    llama_model_free(model);
+    llama_backend_free();
+    return 0;
+}
